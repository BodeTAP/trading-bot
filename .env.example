# =============================================================
# Trading Bot — Template Konfigurasi
# Salin file ini ke .env lalu isi nilai yang sesuai
# cp .env.example .env
# =============================================================

# ── Binance API ───────────────────────────────────────────────
BINANCE_API_KEY=isi_api_key_binance_anda
BINANCE_SECRET_KEY=isi_secret_key_binance_anda

# true  = testnet (aman untuk uji coba, tidak pakai uang nyata)
# false = live trading (pakai uang nyata)
BINANCE_SANDBOX=true

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=isi_anthropic_api_key_anda

# ── Telegram Notifikasi ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=isi_token_dari_botfather
TELEGRAM_CHAT_ID=isi_chat_id_anda

# ── Trading Settings ──────────────────────────────────────────
# Pair yang diperdagangkan: BTC/USDT, ETH/USDT, BNB/USDT, SOL/USDT
TRADING_PAIR=ETH/USDT

# Timeframe analisis
TIMEFRAME_SHORT=1h
TIMEFRAME_MEDIUM=4h
TIMEFRAME_LONG=1d

# ── Risk Management ───────────────────────────────────────────
# Maksimal kerugian dari modal awal sebelum bot berhenti otomatis (%)
MAX_DRAWDOWN_PCT=20

# Maksimal % modal yang dipakai per order
MAX_POSITION_SIZE_PCT=20

# Jarak trailing stop dari harga (ATR multiplier)
# Lebih besar = stop lebih longgar (cocok untuk trending market)
TRAILING_STOP_ATR_MULTIPLIER=1.5

# ── Ensemble Signal Threshold ─────────────────────────────────
# Bot BUY jika skor ensemble >= nilai ini (0.0 - 1.0)
ENSEMBLE_BUY_THRESHOLD=0.30

# Bot SELL jika skor ensemble <= nilai ini (-1.0 - 0.0)
ENSEMBLE_SELL_THRESHOLD=-0.30
